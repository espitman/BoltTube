<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/tv_dialog_bg"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/actionDialogLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/vazir"
        android:text="Video Actions"
        android:textColor="@color/tv_muted"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/actionDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:fontFamily="@font/vazir"
        android:maxLines="2"
        android:textColor="@color/tv_text"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/actionOffloadButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_tv_dialog_secondary_button"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/vazir"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:text="Offload"
        android:textColor="@color/tv_text"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/actionDeleteButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_tv_dialog_primary_button"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/vazir"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:text="Delete"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/actionCancelButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_tv_dialog_secondary_button"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:fontFamily="@font/vazir"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:text="Cancel"
        android:textColor="@color/tv_text"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
