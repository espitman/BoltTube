<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tv_background"
    android:orientation="horizontal">

    <!-- LEFT SIDEBAR -->
    <ScrollView
        android:layout_width="220dp"
        android:layout_height="match_parent"
        android:background="@color/tv_sidebar_bg"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <!-- LOGO -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_tv_launcher" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/vazir"
                    android:text="BoltTube"
                    android:textColor="@color/tv_sidebar_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/vazir"
                android:text="MENU"
                android:textColor="@color/tv_sidebar_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sidebarHome"
                style="@style/SidebarItem"
                android:drawableStart="@drawable/ic_home"
                android:nextFocusRight="@id/rowsContainer"
                android:text="Home" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/vazir"
                android:text="CHANNELS"
                android:textColor="@color/tv_sidebar_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sidebarChannels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:nextFocusUp="@id/sidebarHome"
                android:scrollbars="none" />

            <!-- EXTRA SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/vazir"
                android:text="EXTRA"
                android:textColor="@color/tv_sidebar_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sidebarSettings"
                style="@style/SidebarItem"
                android:drawableStart="@drawable/ic_settings"
                android:nextFocusRight="@id/rowsContainer"
                android:text="Settings" />
        </LinearLayout>
    </ScrollView>

    <!-- MAIN CONTENT AREA -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="10dp"
            android:paddingEnd="16dp">

            <TextClock
                android:id="@+id/topClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/vazir"
                android:format12Hour="hh:mm a"
                android:format24Hour="HH:mm"
                android:textColor="@color/tv_text"
                android:textSize="18sp" />
        </RelativeLayout>

        <FrameLayout
            android:id="@+id/rowsContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="@color/tv_background" />
    </LinearLayout>

</LinearLayout>
